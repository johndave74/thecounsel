# ── Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed CORS origins (the frontend dev + preview URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Auth ─────────────────────────────────────────────────────────────────
# REQUIRED in production. Use long random strings (e.g. `openssl rand -hex 48`).
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-production-0000000000000000
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-production-000000000000000
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# bcrypt cost factor
BCRYPT_ROUNDS=12

# ── Database ───────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to server/ or absolute).
DATABASE_PATH=./data/counsel.db

# ── Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=26214400
