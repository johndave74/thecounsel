{
  "name": "counsel-law-firm-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The Counsel — production-grade backend API for the law firm case management system",
  "main": "src/index.js",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node src/index.js",
